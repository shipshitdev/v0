{
  "name": "@shipshitdev/v0",
  "version": "0.0.3",
  "description": "Opinionated Shipshit.dev project scaffolder.",
  "type": "module",
  "homepage": "https://v0.shipshit.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shipshitdev/v0.git"
  },
  "bugs": {
    "url": "https://github.com/shipshitdev/v0/issues"
  },
  "keywords": [
    "scaffold",
    "bun",
    "turbo",
    "nextjs",
    "codex",
    "claude",
    "shipshitdev"
  ],
  "bin": {
    "v0": "dist/index.js"
  },
  "files": [
    "dist",
    "scripts/link-local-bin.mjs",
    "skills",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepare": "node scripts/link-local-bin.mjs",
    "site:build": "bun run build",
    "typecheck": "tsc --noEmit",
    "lint": "bunx biome check src/ --formatter-enabled=false --assist-enabled=false --files-ignore-unknown=true",
    "lint:fix": "bunx biome check --write src/",
    "format:check": "bunx biome check src/ --linter-enabled=false --assist-enabled=false --files-ignore-unknown=true",
    "deps:update": "bun update --latest",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "tsup": "8.5.1",
    "typescript": "6.0.3"
  },
  "packageManager": "bun@1.3.13",
  "dependencies": {
    "@inquirer/prompts": "^8.4.2"
  }
}
