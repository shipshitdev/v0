{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "isolatedModules": true,
    "types": ["node"],
    "ignoreDeprecations": "6.0",
    "noEmit": true
  },
  "include": ["src/**/*.ts"]
}

